# ============================================
# Assessor SaaS — Environment Variables
# Copy to .env and preencha com valores reais
# NUNCA commite o .env real!
# ============================================

# --- Ambiente ---
NODE_ENV=development

# --- Banco de dados ---
POSTGRES_USER=assessor
POSTGRES_PASSWORD=dev_change_me_in_prod
POSTGRES_DB=assessor_dev
POSTGRES_PORT=5432
DATABASE_URL="postgresql://assessor:dev_change_me_in_prod@localhost:5432/assessor_dev?schema=public"

# --- Redis (cache + filas BullMQ) ---
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3333
API_URL=http://localhost:3333

# --- Web ---
WEB_PORT=3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# --- Auth / JWT ---
# Gerar com: openssl rand -base64 64
JWT_SECRET=change_me_32_bytes_minimum_random_string_here
JWT_REFRESH_SECRET=another_random_string_different_from_above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/auth/google/callback

# --- WhatsApp (Evolution API) ---
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change_me_strong_random_string
EVOLUTION_WEBHOOK_URL=http://localhost:3333/webhooks/whatsapp

# --- IA ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Criptografia de campos sensíveis ---
# Gerar com: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=

# --- Billing (configurar na Fase 3) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ASAAS_API_KEY=

# --- Observabilidade (opcional) ---
SENTRY_DSN=
